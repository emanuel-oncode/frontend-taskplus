---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="register">
  <section class="w-full min-h-screen py-5 flex items-center wallpaper">
    <div
      class="w-full min-h-140 backdrop-blur-md max-w-xl border border-white mx-auto shadow-xl
      rounded-3xl flex flex-col justify-center p-10 text-white"
    >
      <h1 class="text-center text-5xl mb-5 font-bold">Registrate!</h1>
      <form
        id="register"
        class="h-full overflow-hidden flex flex-col justify-center
      gap-10 py-10 px-2"
      >
        <div>
          <input
            type="email"
            id="userEmail"
            placeholder="Email"
            required
            class="w-full p-2 border-b border-white focus:bg-neutral-400/30 focus:outline-0 rounded-t-md transition ease duration-200"
          />
        </div>

        <div>
          <input
            type="text"
            id="userName"
            placeholder="Name"
            required
            class="w-full p-2 border-b border-white focus:bg-neutral-400/30 focus:outline-0 rounded-t-md transition ease duration-200"
          />
        </div>

        <div>
          <input
            type="text"
            id="userLastName"
            placeholder="Last Name"
            required
            class="w-full p-2 border-b border-white focus:bg-neutral-400/30 focus:outline-0 rounded-t-md transition ease duration-200"
          />
        </div>

        <div>
          <label for="birthdate" class="p-2 text-[#798081] font-semibold"
            >Birthdate:</label
          >
          <input
            type="date"
            max="2026-01-12"
            id="birthdate"
            placeholder="birthdate"
            required
            class="w-full p-2 border-b text-[#798081] font-semibold border-white focus:bg-neutral-400/30 focus:outline-0 rounded-t-md transition ease duration-200"
          />
        </div>

        <div>
          <input
            type="password"
            id="userPassword"
            placeholder="Password"
            required
            class="w-full p-2 border-b border-white focus:bg-neutral-400/30 focus:outline-0 rounded-t-md transition ease duration-200"
          />
        </div>

        <button
          type="submit"
          class="w-full h-12 cursor-pointer bg-green-100 hover:bg-green-200 border border-white text-black font-bold
            rounded-md shadow-md transition ease duration-200"
        >
          Login
        </button>
      </form>
      <a
        href="/login"
        class="text-center text-neutral-50 hover:text-neutral-100 transition ease-in-out duration-200 pt-2 text-xs"
      >
        Do you already have an account? Log in
      </a>
      <div id="messageError"></div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("register");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const email = document.getElementById("userEmail") as HTMLInputElement;
    const userEmail = email.value;

    const name = document.getElementById("userName") as HTMLInputElement;
    const userName = name.value;

    const lastName = document.getElementById(
      "userLastName",
    ) as HTMLInputElement;
    const userLastName = lastName.value;

    const birthdate = document.getElementById("birthdate") as HTMLInputElement;
    const userBirthdate = birthdate.value;

    const password = document.getElementById(
      "userPassword",
    ) as HTMLInputElement;
    const userPassword = password.value;

    try {
      const req = await fetch("http://localhost:1234/user/register", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        credentials: "include",
        body: JSON.stringify({
          userName,
          userLastName,
          userBirthdate,
          userEmail,
          userPassword,
        }),
      });

      if (!req.ok) {
        const errorText = await req.text();
        const messageContainer = document.getElementById("messageError");

        if (messageContainer) {
          const errorData = JSON.parse(errorText);
          messageContainer.innerHTML = `<p class="text-red-600 font-bold">${errorData.message}</p>`;
        }
      }

      const result = await req.json();
      alert(JSON.stringify(result));
    } catch (error) {
      console.error("Error completo:", error);
    }
  });
</script>

<style>
  .wallpaper {
    background-image: url("./fondo.webp");
    background-repeat: no-repeat;
    background-position: bottom;
    object-fit: cover;
  }
</style>
