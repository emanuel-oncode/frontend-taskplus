---
import CreateTask from "@/components/CreateTask.astro";
import { MapTask } from "@/components/React/MapTask";
import App from "@/layouts/App.astro";
---

<App title="index">
  <section class="flex flex-col gap-5 w-full max-w-md md:max-w-4xl mx-auto">
    <header>
      <h2 class="text-5xl font-bold text-center">Tareas</h2>
    </header>
    <MapTask client:load />
    <CreateTask />
    <a href="/register" class="font-bold text-center">
      ¿Todavia no te registraste? ¡Click aquí!
    </a>
  </section>
</App>
